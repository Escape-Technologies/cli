# Test: Tags full CRUD lifecycle
# Creates a tag, lists, updates (via delete+recreate since no update cmd), then deletes.

# 1.1 Create tag
exec escape tags create -n e2e-test-tag -c FF0000 -o json
json-valid
json-extract id TAG_ID

# 1.2 List contains tag
exec escape tags list -o json
json-valid
json-contains e2e-test-tag

# 1.5 Delete tag
exec escape tags delete ${TAG_ID}

# 1.6 List no longer contains deleted tag
exec escape tags list -o json
! json-contains ${TAG_ID}

# 1.7 Delete nonexistent tag fails
! exec escape tags delete 00000000-0000-0000-0000-000000000000
