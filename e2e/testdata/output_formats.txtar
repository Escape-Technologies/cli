# Test: Output formats
# Verifies all output formats work correctly on a simple command.

# First create a tag so we have data to display
exec escape tags create -n e2e-output-test -c 00FF00 -o json
json-extract id TAG_ID

# 10.1 JSON output
exec escape tags list -o json
json-valid

# 10.2 YAML output
exec escape tags list -o yaml
yaml-valid

# 10.3 Pretty output (default)
exec escape tags list -o pretty
stdout 'ID'
stdout 'NAME'

# 10.4 Schema output
exec escape tags list -o schema
json-valid
stdout 'type'

# 10.5 Input schema
exec escape assets create --input-schema
json-valid
stdout 'properties'

# Cleanup
exec escape tags delete ${TAG_ID}
