# Test: Version and help commands

# 12.1 Version outputs version info
exec escape version
stdout 'Version'

# 12.2 Help contains main commands
exec escape --help
stdout 'scans'
stdout 'issues'
stdout 'assets'

# 12.3 Help-all contains subcommands
exec escape help-all
stdout 'profiles'
stdout 'tags'

# 12.4 Unknown command fails
! exec escape nonexistent-command
