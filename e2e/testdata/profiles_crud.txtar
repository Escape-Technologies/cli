# Test: Profiles full CRUD lifecycle
# Creates an asset, then a webapp profile on it, gets, lists, and deletes.

# Create the asset first
stdin asset.json
exec escape assets create -o json
json-valid
json-extract id ASSET_ID

# 3.1 Create webapp profile (start=false to avoid launching a scan)
env-subst profile.json.tmpl profile.json
stdin profile.json
exec escape profiles create-webapp -o json
json-valid
json-extract id PROFILE_ID

# 3.2 Get profile
exec escape profiles get ${PROFILE_ID} -o json
json-valid
json-equal id ${PROFILE_ID}

# 3.3 List by kind
exec escape profiles list -k FRONTEND_DAST -o json
json-valid

# 3.4 List by asset
exec escape profiles list -a ${ASSET_ID} -o json
json-valid
json-contains ${PROFILE_ID}

# 3.5 Delete profile
exec escape profiles delete ${PROFILE_ID}

# Cleanup: delete the asset
exec escape assets delete ${ASSET_ID}

-- asset.json --
{"asset_class": "FRONTEND", "asset_type": "WEBAPP", "url": "https://e2e-test-profiles.example.com"}
-- profile.json.tmpl --
{"assetId": "${ASSET_ID}", "name": "e2e-test-profile", "start": false}
