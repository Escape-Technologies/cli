# Test: Assets full CRUD lifecycle
# Creates an asset, gets it, updates it, lists with filters, then deletes.

# 2.1 Create asset
stdin asset.json
exec escape assets create -o json
json-valid
json-extract id ASSET_ID

# 2.2 Get asset
exec escape assets get ${ASSET_ID} -o json
json-valid
json-equal id ${ASSET_ID}

# 2.3 Update description
exec escape assets update ${ASSET_ID} -d 'E2E test asset' -o json

# 2.5 List with type filter returns valid JSON
exec escape assets list -t WEBAPP -o json
json-valid

# 2.9 Delete asset
exec escape assets delete ${ASSET_ID}

# 2.10 Get deleted asset shows DEPRECATED status (soft delete)
exec escape assets get ${ASSET_ID} -o json
json-equal status DEPRECATED

-- asset.json --
{"asset_class": "FRONTEND", "asset_type": "WEBAPP", "url": "https://e2e-test-asset.example.com"}
